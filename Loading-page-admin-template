                  <CardTitle style={{ color: config.primary }}>{config.noticeTitle}</CardTitle>
                </CardHeader>
                <CardContent className="text-base leading-7 text-slate-200">{config.noticeText}</CardContent>
              </Card>
              <Card className="rounded-[28px] border-white/10 bg-black/35 text-white backdrop-blur-sm">
                <CardHeader>
                  <CardTitle style={{ color: config.primary }}>Quick Actions</CardTitle>
                </CardHeader>
                <CardContent className="grid gap-3">
                  <Button className="justify-start rounded-2xl bg-white/10 hover:bg-white/20"><Save className="mr-2 h-4 w-4" /> Auto-saved to browser</Button>
                  <Button className="justify-start rounded-2xl bg-white/10 hover:bg-white/20"><Palette className="mr-2 h-4 w-4" /> Editable colors & style</Button>
                  <Button className="justify-start rounded-2xl bg-white/10 hover:bg-white/20"><Upload className="mr-2 h-4 w-4" /> Upload images directly</Button>
                </CardContent>
              </Card>
            </div>

            <div className="space-y-6">
              {visibleCards.map((card) => (
                <PromoCard key={card.id} card={card} config={config} />
              ))}
            </div>
          </section>
        </main>
      </div>
    </div>
  );
}

